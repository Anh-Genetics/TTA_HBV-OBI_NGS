// ── config/slurm.config ───────────────────────────────────
// SLURM cluster configuration

process {
    executor       = 'slurm'
    clusterOptions = '--account=your_account'   // adjust as needed

    withLabel: 'process_single' {
        queue = 'short'
        time  = '1.h'
    }
    withLabel: 'process_low' {
        queue = 'short'
        time  = '2.h'
    }
    withLabel: 'process_medium' {
        queue = 'normal'
        time  = '4.h'
    }
    withLabel: 'process_high' {
        queue = 'normal'
        time  = '8.h'
    }
    withLabel: 'process_long' {
        queue = 'long'
        time  = '24.h'
    }
}

executor {
    name            = 'slurm'
    queueSize       = 50
    pollInterval    = '30 sec'
    submitRateLimit = '10/1min'
}
