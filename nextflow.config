// ============================================================
// TTA_HBV-OBI_NGS  —  nextflow.config
// ============================================================

manifest {
    name            = 'TTA_HBV-OBI_NGS'
    author          = 'Anh-Genetics'
    description     = 'Illumina NGS pipeline for HBV genotyping and OBI mutation analysis'
    version         = '1.0.0'
    nextflowVersion = '>=23.04.0'
    mainScript      = 'main.nf'
    doi             = ''
}

// ── Default parameters (can be overridden on CLI) ─────────

params {
    help             = false
    samplesheet      = null
    outdir           = 'results'

    // References
    hbv_ref          = "${projectDir}/resources/hbv_references/hbv_genotype_panel.fasta"
    genotype_refs    = "${projectDir}/resources/hbv_references/hbv_genotype_panel.fasta"
    obi_db           = "${projectDir}/resources/knowledge_base/obi_mutations.tsv"

    // QC
    skip_trimming    = false
    fastp_args       = '--detect_adapter_for_pe --qualified_quality_phred 20 --length_required 50'

    // Host filter
    host_filter      = false
    host_ref         = null

    // Variant calling
    min_af           = 0.03
    min_depth        = 10
    ivar_min_freq    = 0.03
    ivar_min_depth   = 10

    // Genotyping
    genotype_method  = 'phylo'

    // Reporting
    multiqc_config   = "${projectDir}/config/multiqc_config.yml"
    html_report      = true

    // Resource limits
    max_memory       = '16.GB'
    max_cpus         = 8
    max_time         = '48.h'
}

// ── Process defaults ──────────────────────────────────────

process {
    // Default resources
    cpus   = 2
    memory = '4.GB'
    time   = '2.h'

    errorStrategy = { task.exitStatus in [143, 137, 104, 134, 139] ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'

    // Per-process resource tuning
    withLabel: 'process_single' {
        cpus   = 1
        memory = '2.GB'
        time   = '1.h'
    }
    withLabel: 'process_low' {
        cpus   = 2
        memory = '4.GB'
        time   = '2.h'
    }
    withLabel: 'process_medium' {
        cpus   = 4
        memory = '8.GB'
        time   = '4.h'
    }
    withLabel: 'process_high' {
        cpus   = 8
        memory = '16.GB'
        time   = '8.h'
    }
    withLabel: 'process_long' {
        cpus   = 4
        memory = '8.GB'
        time   = '24.h'
    }
}

// ── Profiles ──────────────────────────────────────────────

profiles {

    // ---------- local (default) ----------
    local {
        process.executor = 'local'
    }

    // ---------- conda ----------
    conda {
        conda.enabled        = true
        conda.useMamba       = true
        process.conda        = "${projectDir}/environment.yml"
        docker.enabled       = false
        singularity.enabled  = false
    }

    // ---------- docker ----------
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        conda.enabled          = false
        singularity.enabled    = false
        // Container assignments are defined in config/docker.config
        // Load it with: -profile docker (nextflow.config includes base.config)
    }

    // ---------- singularity / apptainer ----------
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        conda.enabled          = false
    }

    apptainer {
        apptainer.enabled    = true
        apptainer.autoMounts = true
        docker.enabled       = false
        conda.enabled        = false
    }

    // ---------- SLURM ----------
    slurm {
        process.executor = 'slurm'
        process.queue    = 'normal'
        executor {
            queueSize    = 50
            submitRateLimit = '10 sec'
        }
    }

    // ---------- test / smoke ----------
    test {
        params.samplesheet   = "${projectDir}/tests/samplesheet_test.csv"
        params.hbv_ref       = "${projectDir}/tests/data/hbv_ref_small.fasta"
        params.genotype_refs = "${projectDir}/tests/data/hbv_ref_small.fasta"
        params.outdir        = 'results/test'
        params.host_filter   = false
        params.html_report   = false
        params.max_memory    = '4.GB'
        params.max_cpus      = 2
        params.max_time      = '1.h'
    }
}

// ── Execution tracing and reporting ──────────────────────

def trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')

timeline {
    enabled = true
    overwrite = true
    file    = "${params.outdir}/pipeline_info/execution_timeline_${trace_timestamp}.html"
}

report {
    enabled = true
    overwrite = true
    file    = "${params.outdir}/pipeline_info/execution_report_${trace_timestamp}.html"
}

trace {
    enabled = true
    overwrite = true
    file    = "${params.outdir}/pipeline_info/execution_trace_${trace_timestamp}.tsv"
    fields  = 'task_id,hash,native_id,process,tag,name,status,exit,module,container,cpus,time,disk,memory,attempt,submit,start,complete,duration,realtime,queue,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar'
}

dag {
    enabled = true
    overwrite = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag_${trace_timestamp}.html"
}

// ── Nextflow settings ─────────────────────────────────────

nextflow.enable.dsl = 2

// Capture container versions
process.beforeScript = 'echo $HOSTNAME'
